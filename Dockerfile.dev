# SafeSplit Go node — DEV image with live reload (Air).
# Source is mounted as a volume; Air rebuilds + restarts on every .go change.
FROM golang:1.25

WORKDIR /app

# Live-reload tool.
RUN go install github.com/air-verse/air@latest
ENV PATH="/go/bin:${PATH}"

EXPOSE 8081

# Air rebuilds + restarts on change. (go.sum is committed; run `go mod tidy`
# manually after adding new dependencies.)
CMD ["air", "-c", ".air.toml"]
